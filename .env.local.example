# 複製本檔為 .env.local 後填入。全部皆為「選用」——不填也能用核心功能（本機 localStorage）。

# ===== Firebase（Google 登入 + 跨裝置同步，選用）=====
# 取得：Firebase Console → 專案設定 → 一般 → 你的網頁應用程式。
# 網頁版 apiKey 不是機密、可公開；安全性靠 firestore.rules。
# 這六項都填齊後，右上角才會出現「登入同步」按鈕。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ===== Anthropic（AI 出題 Part 5/6/7，選用）=====
ANTHROPIC_API_KEY=
# 省成本可改用 haiku：
# ANTHROPIC_MODEL=claude-haiku-4-5

# ===== 爬蟲翻譯額度（選用，見 README〈擴充到 4000 字〉）=====
# MYMEMORY_EMAIL=you@example.com
